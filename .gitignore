### Python ###
# Byte-compiled files
*.py[cod]
__pycache__/

# Django
*.log               # Log files
*.pot               # Translation files
db.sqlite3          # Default SQLite DB (you're using PostgreSQL)
media/              # User-uploaded media (should be in .gitignore)

# Environments
.env                # Environment variables (critical to exclude!)
.venv/              # Python virtual environment
venv/
env/
backend/.env
backend/.venv

### Node/React ###
node_modules/       # Node dependencies (never commit)
dist/              # Build output
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

### IDE ###
.idea/             # JetBrains IDE
.vscode/           # VS Code config
*.swp              # Vim swap files
*.swo

### System ###
.DS_Store          # macOS metadata
Thumbs.db          # Windows thumbnail cache

### Database ###
*.sql              # SQL dumps (you might generate these)
*.sqlite           # SQLite variants

### Testing ###
.coverage          # Coverage reports
htmlcov/          # HTML coverage reports
.pytest_cache/    # Pytest cache

### Docs ###
docs/_build/      # Built documentation
/docs